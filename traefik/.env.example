# Domain for the Traefik dashboard (e.g. traefik.yourdomain.com)
TRAEFIK_DOMAIN=traefik.404notfound.fun

# Let's Encrypt registration email
ACME_EMAIL=iqbaleff214@gmail.com

# BasicAuth for the Traefik dashboard.
# Generate with: docker run --rm httpd:alpine htpasswd -nB admin
# Then escape every $ sign as $$ below.
# Example output: admin:$2y$05$... → admin:$$2y$$05$$...
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$changeme