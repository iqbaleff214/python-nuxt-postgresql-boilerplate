# ============================================================
# Application
# ============================================================
APP_NAME=MyApp
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-me-in-production-must-be-at-least-32-characters-long

# Fernet key for encrypting TOTP secrets at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=

FRONTEND_URL=http://localhost:3000

# ============================================================
# Database (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/myapp

# Postgres container settings (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=myapp

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://redis:6379/0

# ============================================================
# JWT / Auth Tokens
# ============================================================
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_CHALLENGE_TOKEN_EXPIRE_MINUTES=5

# ============================================================
# Email
# ============================================================
MAIL_PROVIDER=smtp           # smtp | sendgrid | resend
MAIL_FROM=noreply@myapp.com
MAIL_FROM_NAME=MyApp

# SMTP (dev: use MailHog defaults below)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_TLS=false               # true for production SMTP

# SendGrid (if MAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Resend (if MAIL_PROVIDER=resend)
RESEND_API_KEY=

# ============================================================
# File Storage
# ============================================================
STORAGE_BACKEND=local        # local | s3

# Local storage (dev default)
STORAGE_PATH=./uploads

# S3-compatible (AWS S3, Cloudflare R2, MinIO)
S3_ENDPOINT_URL=             # Leave empty for AWS. MinIO dev: http://minio:9000
S3_BUCKET_NAME=myapp
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_URL=               # Optional CDN base URL for public files

# ============================================================
# Frontend (Nuxt.js)
# ============================================================
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NUXT_PUBLIC_WS_BASE=ws://localhost:8000
