APP_NAME=MyApp
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-at-least-32-chars
TOTP_ENCRYPTION_KEY=  # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/myapp

REDIS_URL=redis://redis:6379/0

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_CHALLENGE_TOKEN_EXPIRE_MINUTES=5

MAIL_PROVIDER=smtp
MAIL_FROM=noreply@myapp.com
MAIL_FROM_NAME=MyApp
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=
RESEND_API_KEY=

STORAGE_BACKEND=local
STORAGE_PATH=./uploads
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PUBLIC_URL=
